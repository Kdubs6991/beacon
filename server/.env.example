PORT=3001
SESSION_SECRET=changeme-use-a-long-random-string

# Seeded admin account — created on first startup if it doesn't exist
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=changeme123

# Planning Center OAuth — fill in when ready
PCO_CLIENT_ID=YOUR_CLIENT_ID_HERE
PCO_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
PCO_REDIRECT_URI=http://localhost:3001/api/auth/pco/callback

# Set to 'true' to use mock data instead of PCO
USE_MOCK_DATA=true
