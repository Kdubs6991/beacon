# ── Required ──────────────────────────────────────────────────────────────────
# Auto-generated on first run if not set. You can set your own here.
SESSION_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Optional: pre-seed an admin account on first start ────────────────────────
# If these are set, an admin user is created automatically on startup.
# Leave blank to create your account through the setup wizard instead.
ADMIN_EMAIL=
ADMIN_NAME=
ADMIN_PASSWORD=

# ── Optional: SMTP email ───────────────────────────────────────────────────────
# Can also be configured in the admin UI: Admin → Organization → Email / SMTP
# Use a Gmail App Password, not your regular Google password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Planning Center (not yet available) ───────────────────────────────────────
PCO_CLIENT_ID=
PCO_CLIENT_SECRET=
PCO_REDIRECT_URI=http://localhost:3001/api/auth/pco/callback
