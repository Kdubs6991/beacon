# ── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required for web deployment)
# Railway: copy from your PostgreSQL service's connection panel
# Render:  copy from your PostgreSQL service's external URL
DATABASE_URL=postgresql://user:password@host:5432/beacon

# Session secret — must be set to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Optional: pre-seed an admin account on first start ────────────────────────
# If these are set, an admin user is created automatically on startup.
# Leave blank to create your account through the setup wizard instead.
ADMIN_EMAIL=
ADMIN_NAME=
ADMIN_PASSWORD=

# ── Optional: SMTP email ───────────────────────────────────────────────────────
# Can also be configured in the admin UI: Admin → Organization → Email / SMTP
# Use a Gmail App Password, not your regular Google password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Cloudflare R2 photo storage (optional but recommended for web deployments) ─
# Without these, photos are saved to local disk and lost on every redeploy.
# Setup: cloudflare.com → R2 → create bucket → manage API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=beacon-uploads
# The public URL for your bucket — enable "Public Access" on the bucket to get this
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ── Planning Center OAuth ──────────────────────────────────────────────────────
# Change the redirect URI to your production domain
PCO_CLIENT_ID=
PCO_CLIENT_SECRET=
PCO_REDIRECT_URI=https://yourdomain.com/api/auth/pco/callback
